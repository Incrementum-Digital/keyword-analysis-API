# Copy this file to .env and add your actual API keys

# ===========================================
# REQUIRED API Keys
# ===========================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
KEEPA_API_KEY=your_keepa_api_key_here

# ===========================================
# Model Configuration
# ===========================================
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# ===========================================
# Production Configuration
# ===========================================

# Number of gunicorn workers (recommended: 2-4 for Railway)
# Formula: (2 x CPU cores) + 1
WORKERS=4

# Maximum concurrent API requests to OpenRouter (prevents rate limiting)
# Recommended: 10-20 for production, 0 = unlimited (not recommended)
MAX_CONCURRENT_REQUESTS=10

# Keywords per batch sent to AI
BATCH_SIZE=30

# Request timeout in seconds (per batch, not total)
REQUEST_TIMEOUT=120

# ===========================================
# CORS Configuration
# ===========================================
# For production: Set to your Chrome extension ID or frontend domain
# Example: "chrome-extension://your-extension-id" or "https://your-frontend.com"
# Use "*" only for development
FRONTEND_URL=*

# ===========================================
# Server Configuration
# ===========================================
# Port (Railway/Coolify sets $PORT automatically)
PORT=8000

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info
